# BrightCare Clinic — copy to .env.local / .env and fill in.

# Clinic
CLINIC_NAME=BrightCare Clinic
CLINIC_TIMEZONE=Asia/Singapore

# OpenAI (NLU)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
# polling (local) or webhook (deployed)
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_SECRET=
PUBLIC_BASE_URL=
# HTTPS URL to the Mini App page (required for in-Telegram app button)
# e.g. https://your-app.vercel.app/telegram
TELEGRAM_WEBAPP_URL=
NEXT_PUBLIC_TELEGRAM_WEBAPP_URL=

# Google Calendar
GOOGLE_CALENDAR_ID=
# Local file path (dev):
GOOGLE_SERVICE_ACCOUNT_FILE=credentials.json
# Cloud (Render/Railway): paste full JSON of credentials.json, or base64 of the file
GOOGLE_SERVICE_ACCOUNT_JSON=

# Gmail SMTP — must be a Google App Password (16 chars), NOT your normal Gmail password.
# Create one: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_APP_PASSWORD=
SMTP_FROM=

# Clerk (web dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWKS_URL=

# Next → FastAPI proxy (optional)
API_PROXY_URL=http://127.0.0.1:8000

# Persistence (sqlite for local/deploy; memory for tests)
SESSION_STORE=sqlite
DATA_DIR=data

# Protect cron job endpoints (optional)
JOBS_SECRET=
