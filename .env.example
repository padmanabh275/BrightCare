# BrightCare Clinic — copy to .env.local / .env and fill in.

# Clinic
CLINIC_NAME=BrightCare Clinic
CLINIC_TIMEZONE=Asia/Singapore

# OpenAI (NLU)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
# polling (local) or webhook (deployed)
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_SECRET=
PUBLIC_BASE_URL=
# HTTPS URL to the Mini App page (required for in-Telegram app button)
# e.g. https://your-app.vercel.app/telegram
TELEGRAM_WEBAPP_URL=
NEXT_PUBLIC_TELEGRAM_WEBAPP_URL=

# Google Calendar
GOOGLE_CALENDAR_ID=
# Local file path (dev):
GOOGLE_SERVICE_ACCOUNT_FILE=credentials.json
# Cloud (Render/Railway): paste full JSON of credentials.json, or base64 of the file
GOOGLE_SERVICE_ACCOUNT_JSON=

# Email — prefer Resend HTTPS on Render free (SMTP ports are blocked there).
# https://resend.com/api-keys  → RESEND_API_KEY
# Until your domain is verified, use: EMAIL_FROM=BrightCare <onboarding@resend.dev>
# (can only send to your Resend signup email). Then verify a domain for clinic mail.
RESEND_API_KEY=
EMAIL_FROM=
# Optional local Gmail SMTP fallback (works off Render free / on paid Render):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_APP_PASSWORD=
SMTP_FROM=

# Clerk (web dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWKS_URL=

# Next → FastAPI proxy (optional)
API_PROXY_URL=http://127.0.0.1:8000

# Database — Neon Postgres (preferred for Render / Vercel / production)
# Create at https://console.neon.tech → copy connection string
DATABASE_URL=
# NEON_DATABASE_URL=   # alias also accepted

# Local fallback when DATABASE_URL is empty (tests use SESSION_STORE=memory)
SESSION_STORE=sqlite
DATA_DIR=data

# Protect cron job endpoints (optional)
JOBS_SECRET=
